Redirect 301 /blog/komplexny-pruvodce-modernim-internetovym-pripojenim-2025 /blog/nejlepsi-internet-ostrava-karvina-havirov-pruvodce-2025
Redirect 301 /blog/opticky-internet-ostrava /blog/internet-poda-ostrava-nejrychlejsi-opticke-pripojeni-moravskoslezsky-kraj-2025
Redirect 301 /blog/rychly-internet-karvina /blog/rychly-internet-karvina-revoluce-pripojeni-domacnosti-poda
Redirect 301 /blog/internet-poda-ostrava-nejrychlejsi-opticke-pripojeni-v-moravskoslezskem-kraji-2025-500 /blog/internet-poda-ostrava-nejrychlejsi-opticke-pripojeni-moravskoslezsky-kraj-2025
Redirect 301 /blog/wifi-optimalizace /blog/jak-zlepsit-wifi-signal-doma-10-overenych-triku-2025
Redirect 301 /blog/domaci-sit-nastaveni /blog
Redirect 301 /blog/opticky-internet-vyhody /blog
Redirect 301 /blog/gpon-technologia-v-moravskoslezskom-regione-revolucia-optickeho-internetu-1 /blog/gpon-technologie-moravskoslezsky-region-revoluce-optickeho-internetu
Redirect 301 /blog/prechod-od-o2-k-poda-po-akvizicii-nejcz-a-netboxu-prilezitost-pre-lepsie-sluzby-v-moravskoslezskom-regione-101 /blog/o2-nej-prevzatie-poda-alternativa-zakaznici
Redirect 301 /blog/jednoduchy-prechod-k-poda-od-stavajuceho-poskytovatela-v-moravskoslezskem-regione /blog
Redirect 301 /blog/jednoduchy-prechod-k-poda-od-stavajuceho-poskytovatela-v-moravskoslezskom-regione-3 /blog
Redirect 301 /blog/bleskovy-internet-bez-dratu-poznejte-60-ghz-technologii-a-nabidku-poda-102 /blog/polanka-nad-odrou-60ghz-pripojeni-2025

# Block all remaining ID-based blog URLs with RewriteRule
RewriteCond %{REQUEST_URI} ^/blog/[0-9]+$
RewriteRule ^blog/([0-9]+)$ /blog/ [R=301,L]

# Clean up query parameters for canonical URLs
RewriteCond %{QUERY_STRING} .
RewriteCond %{REQUEST_URI} ^/blog/
RewriteRule ^(.*)$ /$1? [R=301,L]
# END AUTO BLOG ID->SLUG REDIRECTS

# SPA routing - handle all non-file requests
<IfModule mod_rewrite.c>
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
