
# Apache .htaccess configuration

# Enable URL rewriting
RewriteEngine On

# Force HTTPS - improved and simplified rule
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect old domain to new domain with path preservation
RewriteCond %{HTTP_HOST} ^(www\.)?pripojeni-poda\.cz$ [NC]
RewriteRule ^(.*)$ https://www.popri.cz/$1 [L,R=301]

# Redirect non-www to www for popri.cz - simplified and more robust
RewriteCond %{HTTP_HOST} ^popri\.cz$ [NC]
RewriteRule ^ https://www.popri.cz%{REQUEST_URI} [L,R=301]

# Always force to the www subdomain of popri.cz for canonical URLs
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Special handling for asset files
RewriteCond %{REQUEST_URI} ^/assets/
RewriteRule ^ - [L]

RewriteCond %{REQUEST_URI} ^/lovable-uploads/
RewriteRule ^ - [L]

# Special handling for sitemap files
RewriteRule ^sitemap\.xml$ /sitemap.xml [L]
RewriteRule ^sitemap-popri\.xml$ /sitemap-popri.xml [L]
RewriteRule ^robots\.txt$ /robots.txt [L]

# Set proper MIME types
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/font-woff .woff
  AddType application/font-woff2 .woff2
</IfModule>

# Enable CORS for fonts and other resources
<IfModule mod_headers.c>
  <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font\.css|css|js|png|jpg|jpeg|gif|webp|svg)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# Improved caching rules
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images - extended cache time
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Video
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/mpeg "access plus 1 year"
  
  # CSS, JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Fonts
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  
  # Others
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType application/x-shockwave-flash "access plus 1 month"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  
  # Explicitly allow indexing for search engines
  Header set X-Robots-Tag "index, follow"
  
  # Add Link header for canonical URL
  Header always set Link "<https://www.popri.cz%{REQUEST_URI}>; rel=\"canonical\""
</IfModule>

# Disable directory listing
Options -Indexes

# Handle SPA routing - redirect all routes to index.html
<IfModule mod_rewrite.c>
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
