
# Apache .htaccess configuration - FIXED FOR PROPER DOMAIN MIGRATION

# Enable URL rewriting
RewriteEngine On

# CRITICAL: Force HTTPS first, then handle domain redirects
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# CRITICAL: Redirect old domain to new domain BEFORE www handling
RewriteCond %{HTTP_HOST} ^(www\.)?pripojeni-poda\.cz$ [NC]
RewriteRule ^(.*)$ https://www.popri.cz/$1 [L,R=301]

# CRITICAL: Force www for popri.cz (after old domain redirect)
RewriteCond %{HTTP_HOST} ^popri\.cz$ [NC]
RewriteRule ^(.*)$ https://www.popri.cz$1 [L,R=301]

# Special handling for direct file access
RewriteRule ^sitemap\.xml$ - [L]
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^(poda-favicon.*)\.(ico|png)$ - [L]
RewriteRule ^(site\.webmanifest|apple-touch-icon\.png)$ - [L]

# Handle asset files
RewriteCond %{REQUEST_URI} ^/(assets|lovable-uploads)/
RewriteRule ^ - [L]

# Handle missing images gracefully - exclude lovable-uploads
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} \.(jpg|jpeg|gif|png|webp)$
RewriteCond %{REQUEST_URI} !^/lovable-uploads/
RewriteRule ^(.*)$ /placeholder.svg [L,R=302]

# Set proper MIME types
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/font-woff .woff
  AddType application/font-woff2 .woff2
  AddType image/x-icon .ico
  AddType image/png .png
  AddType application/xml .xml
</IfModule>

# Enhanced caching rules
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Enhanced security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header set X-Robots-Tag "index, follow"
  
  # CRITICAL: Enhanced canonical URL headers
  Header always set Link "<https://www.popri.cz%{REQUEST_URI}>; rel=\"canonical\""
  
  # Enhanced CORS for assets
  <FilesMatch "\.(woff|woff2|ttf|eot|css|js|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# Disable directory listing
Options -Indexes

# BEGIN AUTO BLOG ID->SLUG REDIRECTS
# Direct 301 redirects for old ID-based blog URLs to new slug-based URLs
Redirect 301 /blog/102 /blog/o2-nej-prevzatie-poda-alternativa-zakaznici
Redirect 301 /blog/203 /blog/iptv-vs-traditionalni-tv-srovnani-vyhod-nevyhod
Redirect 301 /blog/204 /blog/nejcastejsi-otazky-pripojeni-internet-panelak
Redirect 301 /blog/201 /blog/polanka-nad-odrou-60ghz-pripojeni-2025
Redirect 301 /blog/31 /blog/internetove-pripojeni-online-hraci-ostrava-rychlosti-ping-spolehlivost-poda
Redirect 301 /blog/30 /blog/pomaly-internet-8-sposobu-jak-vyresit-msk-2025
Redirect 301 /blog/206 /blog/nejlepsi-internet-ostrava-karvina-havirov-pruvodce-2025
Redirect 301 /blog/500 /blog/internet-poda-ostrava-nejrychlejsi-opticke-pripojeni-moravskoslezsky-kraj-2025
Redirect 301 /blog/10 /blog/rychly-internet-karvina-revoluce-pripojeni-domacnosti-poda
Redirect 301 /blog/1 /blog/gigabitovy-internet-poda-ostrava-technologie
Redirect 301 /blog/13 /blog/poda-recenzie-skusenosti-zakaznikov-2025
Redirect 301 /blog/12 /blog/televize-160-programu-hd-uhd-kvalita-2025

# Block all ID-based blog URLs with RewriteRule
RewriteCond %{REQUEST_URI} ^/blog/[0-9]+$
RewriteRule ^blog/([0-9]+)$ /blog/ [R=301,L]

# Clean up query parameters for canonical URLs
RewriteCond %{QUERY_STRING} .
RewriteCond %{REQUEST_URI} ^/blog/
RewriteRule ^(.*)$ /$1? [R=301,L]
# END AUTO BLOG ID->SLUG REDIRECTS

# SPA routing - handle all non-file requests
<IfModule mod_rewrite.c>
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
